{
  "name": "truthify",
  "version": "1.0.0",
  "description": "AI-powered news verification system using LangChain, Temporal, Redis, and PostgreSQL",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "start:all": "concurrently -n \"API,WORKER\" -c \"blue,green\" \"npm start\" \"npm run worker:prod\"",
    "dev": "ts-node-dev --respawn --transpile-only src/api/server.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/workflows/worker.ts",
    "worker:prod": "node dist/workflows/worker.js",
    "db:migrate": "ts-node src/database/migrate.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/groq": "^0.1.3",
    "@langchain/openai": "^0.3.0",
    "@temporalio/activity": "^1.10.0",
    "@temporalio/client": "^1.10.0",
    "@temporalio/worker": "^1.10.0",
    "@temporalio/workflow": "^1.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-validator": "^7.1.0",
    "ioredis": "^5.4.0",
    "langchain": "^0.3.0",
    "pg": "^8.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
